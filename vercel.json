{
  "rewrites": [
    { "source": "/", "destination": "/site/index.html" },
    { "source": "/memes.html", "destination": "/site/memes.html" },
    { "source": "/memes", "destination": "/site/memes.html" },
    { "source": "/admin.html", "destination": "/site/admin.html" },
    { "source": "/admin", "destination": "/site/admin.html" }
  ],
  "headers": [
    {
      "source": "/site/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
